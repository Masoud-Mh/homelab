# Backend CORS: comma-separated origins
CORS_ORIGINS=http://site.local,https://masoud-mh.com,https://www.masoud-mh.com

# Host paths (portability). Optional — compose/scripts default to these values,
# so leaving them unset reproduces current production behavior. Set to relocate
# the stack to a different host without editing compose/scripts/workflows.
#   SITE_ROOT     prod frontend static root (compose mounts ${SITE_ROOT}/frontend)
#   SITE_DEV_ROOT dev frontend static root (docker-compose.dev.yml)
# SITE_ROOT=/srv/site
# SITE_DEV_ROOT=/srv/site-dev
# REPO_ROOT (deploy workflows) is configured as a GitHub Actions repo variable
# (vars.REPO_ROOT), defaulting to /data/repos/homelab-stack.

# Image tags (image-based delivery). Default to latest; deploy workflows set a
# pinned sha-<sha> tag. Backend was already image-based; frontend now matches.
# BACKEND_TAG=latest
# FRONTEND_TAG=latest
